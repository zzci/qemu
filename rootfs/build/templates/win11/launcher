#!/usr/bin/env bash
# Windows 11 launcher template (`launch = "win11"`): copied to {dir}/scripts/ on first boot (edit
# the copy). vmd exports placeholders as VMD_<KEY>; MUST use $VMD_QMP so vmd can control the VM.
set -euo pipefail

exec qemu-system-x86_64 \
    -machine "q35,accel=${VMD_ACCEL}" -cpu "${VMD_CPU}" -smp "${VMD_CPUS}" -m "${VMD_RAM}" \
    -rtc base=localtime -uuid "${VMD_UUID}" -name "${VMD_NAME}" -no-user-config -nodefaults \
    -drive "if=pflash,format=raw,unit=0,readonly=on,file=/usr/share/OVMF/OVMF_CODE_4M.fd" \
    -drive "if=pflash,format=raw,unit=1,file=${VMD_STATE}.OVMF_VARS.fd" \
    -chardev "socket,id=chrtpm,path=${VMD_TPM_SOCK}" \
    -tpmdev emulator,id=tpm0,chardev=chrtpm -device tpm-tis,tpmdev=tpm0 \
    -device virtio-rng-pci -device virtio-balloon-pci -device qemu-xhci -device usb-tablet \
    -device "virtio-vga,xres=1920,yres=1080" -vnc "unix:${VMD_VNC_SOCK}" \
    -netdev user,id=net0,hostfwd=tcp::3389-:3389 -device "virtio-net-pci,netdev=net0,mac=${VMD_MAC}" \
    -monitor none \
    -drive "file=${VMD_DISK},if=none,id=disk0,format=qcow2,cache=writeback" \
    -device virtio-blk-pci,drive=disk0,bootindex=1 \
    -qmp "unix:${VMD_QMP},server,nowait"
